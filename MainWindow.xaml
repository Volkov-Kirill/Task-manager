<Window x:Class="TaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager"
        Height="450" Width="700"
        Background="#F5F6FA">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Padding="12" Background="#F2F4F8" CornerRadius="8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Логин:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,8,0" />
                <TextBox Grid.Column="2" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="Войти" Command="{Binding LoginCommand}" Width="90" Height="30" Margin="0,0,8,0" />
                <TextBlock Grid.Column="4" Text="{Binding CurrentUserInfo}" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Grid.Column="5" Content="Выйти" Command="{Binding LogoutCommand}" Width="90" Height="30" />
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Список задач" Padding="10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Width="180" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Margin="0,0,8,0" />
                        <Button Content="Обновить" Command="{Binding RefreshCommand}" Width="100" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}" AutoGenerateColumns="False"
                         IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Заголовок" Binding="{Binding Title}" Width="2*" />
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="*" />
                            <DataGridCheckBoxColumn Header="Выполнена" Binding="{Binding IsCompleted}" Width="*" />
                            <DataGridTextColumn Header="Создал" Binding="{Binding CreatedByUser.Name}" Width="*" />
                            <DataGridTextColumn Header="Кому" Binding="{Binding ReceiverName}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Создание / редактирование" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Имя задачи" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,4,0,10" />

                        <TextBlock Text="Заголовок" />
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,4,0,10" />

                        <TextBlock Text="Категория" />
                        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,4,0,10" />

                        <CheckBox Content="Задача выполнена" IsChecked="{Binding IsCompleted}" Margin="0,4,0,10" />

                        <StackPanel Visibility="{Binding IsManager, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Назначить работнику" />
                            <ComboBox ItemsSource="{Binding Workers}" SelectedItem="{Binding SelectedWorker}" DisplayMemberPath="Name" Height="30" Margin="0,4,0,10" />
                            <CheckBox Content="Создать задачу для всех работников" IsChecked="{Binding IsForAllWorkers}" Margin="0,0,0,10" />
                        </StackPanel>

                        <WrapPanel Margin="0,8,0,8">
                            <Button Content="Создать" Command="{Binding AddCommand}" Width="90" Height="32" Margin="0,0,8,8" />
                            <Button Content="Сохранить" Command="{Binding UpdateCommand}" Width="90" Height="32" Margin="0,0,8,8" />
                            <Button Content="Удалить" Command="{Binding DeleteCommand}" Width="90" Height="32" Margin="0,0,8,8" />
                            <Button Content="Очистить" Command="{Binding ClearCommand}" Width="90" Height="32" Margin="0,0,8,8" />
                        </WrapPanel>

                        <Border Background="#FFF6D6" Padding="8" CornerRadius="6">
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
